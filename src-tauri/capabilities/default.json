{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the OpenBLS main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-meta",
    "fs:allow-mkdir"
  ]
}
